{
  "name": "capstone-desktop-shell",
  "version": "0.0.1",
  "private": true,
  "main": "dist/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "npm run build:electron && cross-env NODE_ENV=development electron .",
    "build": "tsc -p tsconfig.json",
    "build:electron": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json -w",
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.7.4",
    "electron": "31.0.0",
    "cross-env": "^10.1.0",
    "electron-builder": "^24.13.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
