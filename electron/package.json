{
  "name": "capstone-desktop-shell",
  "version": "0.0.1",
  "private": true,
  "description": "Electron desktop shell for the Portfolio Analysis application.",
  "author": "Team 7",
  "homepage": "https://github.com/COSC-499-W2025/capstone-project-team-7",
  "main": "dist/main.js",
  "type": "commonjs",
  "scripts": {
