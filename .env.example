# Example environment configuration for all features.
# Copy to .env and fill with your project-specific values.
# DO NOT COMMIT YOUR ACTUAL .env FILE.

# =============================================================================
# SUPABASE (required for auth, storage, resume syncing, config manager)
# =============================================================================
SUPABASE_URL=https://bybqsnphnkrjppseubsi.supabase.co  # Shared Supabase project URL
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key        # Service role key (full access, used by backend; distribute separately if needed)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJ5YnFzbnBobmtyanBwc2V1YnNpIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjEyNzMyNDcsImV4cCI6MjA3Njg0OTI0N30.PTnN7yq6tZ-Wq23usMhpfVJx5lEvS_vcU4df9DSF-_I  # Shared anon key for auth/uploads

# Legacy alias (deprecated - use SUPABASE_SERVICE_ROLE_KEY instead)
# SUPABASE_KEY=your-service-role-key                   # Kept for backward compatibility; new code should use SUPABASE_SERVICE_ROLE_KEY

# Local Supabase tooling (optional - for local development with `supabase start`)
SUPABASE_LOCAL=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # Supabase CLI project ref

# =============================================================================
# API SERVER CONFIGURATION
# =============================================================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000  # CORS allowed origins (comma-separated)
PORTFOLIO_API_URL=http://localhost:8000                # Backend API base URL (used by services)

# =============================================================================
# FILE UPLOAD SETTINGS (optional - defaults shown)
# =============================================================================
UPLOAD_DIR=./uploads                                   # Directory for temporary file uploads
MAX_UPLOAD_SIZE_MB=500                                 # Maximum upload size in megabytes
UPLOAD_TTL_SECONDS=3600                                # Time-to-live for uploaded files (seconds)

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000         # API URL accessible from browser (must be NEXT_PUBLIC_ prefixed)

# =============================================================================
# USER-SCOPED SCAN PREFERENCES (optional)
# =============================================================================
SCAN_USER_ID=00000000-0000-0000-0000-000000000000      # CLI/headless parse_zip user ID; TUI uses logged-in session instead

# =============================================================================
# AI FEATURES (optional - required for LLMRemoteMediaAnalyzer)
# =============================================================================
OPENAI_API_KEY=sk-...                                  # OpenAI API key; leave unset to disable AI calls

# =============================================================================
# CLI/TEXTUAL COMMIT ATTRIBUTION (optional)
# =============================================================================
TEXTUAL_SKILL_PROGRESS_EMAILS=user@example.com         # Comma-separated emails to filter timelines
PORTFOLIO_USER_EMAIL=user@example.com                  # Preferred single email; wins if both are set

# =============================================================================
# API FEATURES (optional)
# =============================================================================
PORTFOLIO_USE_API=true                                 # Enable API-based project ranking (false = local calculation only)

# =============================================================================
# SECURITY (reserved/experimental)
# =============================================================================
ENCRYPTION_MASTER_KEY=base64-encoded-key               # Secret encryption key; not currently consumed

# =============================================================================
# ELECTRON DESKTOP APP (optional - development only)
# =============================================================================
ELECTRON_OPEN_DEVTOOLS=false                           # Auto-open DevTools on Electron launch
ELECTRON_START_URL=http://localhost:3000               # URL for Electron to load (dev server)

# =============================================================================
# LINKEDIN API (optional -- required for direct LinkedIn posting)
# NOTE: LinkedIn OAuth uses in-memory state storage, so it only works with a
# single backend instance. For multi-instance deployments, the OAuth callback
# may hit a different process and fail. Move to shared storage (Redis/DB) if needed.
# =============================================================================
LINKEDIN_CLIENT_ID=your-linkedin-client-id          # LinkedIn Developer App Client ID
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret    # LinkedIn Developer App Client Secret
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/linkedin/oauth/callback  # OAuth redirect URI (must point to backend)

# =============================================================================
# JSEARCH JOB SEARCH API (optional — required for live job search)
# =============================================================================
RAPIDAPI_KEY=your-rapidapi-key                         # Free tier: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch

# =============================================================================
# DEBUGGING (optional - development only)
# =============================================================================
# CAPSTONE_LOCAL_STORE=/path/to/local/store           # Override local storage path (testing)
# SKILL_SUMMARY_DEBUG_PATH=/path/to/debug.json        # Path to dump skill summary debug output
# USE_API_MODE=true                                    # Force API mode for testing
